{
  "name": "bunqueue",
  "version": "2.0.3",
  "description": "High-performance job queue server written in Bun. SQLite persistence, cron scheduling, priorities, retries, DLQ, webhooks. Minimal dependencies.",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "bunqueue": "./dist/cli/index.js",
    "bunqueue-mcp": "./dist/mcp/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./queue": {
      "types": "./dist/application/queueManager.d.ts",
      "import": "./dist/application/queueManager.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map",
    "!dist/bunqueue",
    "!dist/benchmark",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .husky",
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "build": "bun build --compile --minify src/main.ts --outfile dist/bunqueue",
    "build:lib": "tsc -p tsconfig.build.json",
    "test": "BUNQUEUE_EMBEDDED=1 bun test",
    "bench": "bun run bench/throughput.ts && bun run bench/latency.ts",
    "bench:throughput": "bun run bench/throughput.ts",
    "bench:latency": "bun run bench/latency.ts",
    "bench:internal": "bun run benchmarks/index.ts",
    "bench:compare": "bun run bench/comparison/run.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "prepublishOnly": "bun run build:lib"
  },
  "dependencies": {
    "msgpackr": "^1.11.0",
    "croner": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "latest",
    "bullmq": "^5.67.2",
    "elysia": "^1.4.22",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "ioredis": "^5.9.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "bun",
    "job-queue",
    "message-queue",
    "task-queue",
    "background-jobs",
    "queue",
    "worker",
    "cron",
    "scheduler",
    "sqlite",
    "redis-alternative",
    "bullmq-alternative",
    "priority-queue",
    "delayed-jobs",
    "retries",
    "dead-letter-queue",
    "dlq",
    "webhooks",
    "prometheus",
    "typescript"
  ],
  "author": "egeominotti",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egeominotti/bunQ.git"
  },
  "bugs": {
    "url": "https://github.com/egeominotti/bunQ/issues"
  },
  "homepage": "https://github.com/egeominotti/bunQ#readme",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
